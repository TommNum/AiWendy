{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "express"]
  },
  "include": [
    "src/**/*",
    "functions/**/*",
    "utils/**/*",
    "workers/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
} 