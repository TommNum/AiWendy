{
  "name": "twitter-example",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/src/wendy-twitter.js",
    "dev": "ts-node --esm src/wendy-twitter.ts",
    "watch": "ts-node-dev --esm --respawn src/wendy-twitter.ts",
    "docker:build": "docker build -t wendy-twitter .",
    "docker:run": "docker run -p 3000:3000 --env-file .env wendy-twitter",
    "docker:logs": "docker logs -f wendy-twitter",
    "railway:up": "railway up"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.12.3",
    "@virtuals-protocol/game": "^0.1.9",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "twitter-api-v2": "^1.15.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/winston": "^2.4.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
