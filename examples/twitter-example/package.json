{
  "name": "twitter-example",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/src/wendy-twitter.js",
    "dev": "ts-node src/wendy-twitter.ts",
    "watch": "ts-node-dev --respawn src/wendy-twitter.ts",
    "docker:build": "docker build -t aiwendy .",
    "docker:run": "docker run -d --env-file .env aiwendy",
    "railway:up": "railway up"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.12.3",
    "@virtuals-protocol/game": "^0.1.9",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "twitter-api-v2": "^1.15.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/winston": "^2.4.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
